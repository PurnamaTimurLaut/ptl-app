generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   
  name      String
  role      String   // DIRECTOR or OPERATIONAL
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  budget      Float
  status      String   @default("RUNNING") // RUNNING, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productions Production[]
}

model Production {
  id           String   @id @default(cuid())
  projectId    String
  menuId       String
  quantity     Int
  assignedDate DateTime
  deadlineDate DateTime
  status       String   @default("ASSIGNED")
  
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// --- DATABASES MODULE ---

// 1. Production Template (e.g., "Nasi Campur")
model ProductionTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  ingredients TemplateIngredient[]
  flows       TemplateExecutionFlow[]
}

// Ingredients belonging to a Production Template
model TemplateIngredient {
  id          String   @id @default(cuid())
  templateId  String
  name        String   
  quantity    Float
  unit        String   
  template    ProductionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// The Execution sequence (e.g. "Prep Ayam") mapped to a specific Recipe 
model TemplateExecutionFlow {
  id          String   @id @default(cuid())
  templateId  String
  name        String   
  recipeId    String?  
  template    ProductionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  recipe      CookingRecipe?     @relation(fields: [recipeId], references: [id])
}

// 2. The actual Cooking Instructions
model CookingRecipe {
  id           String   @id @default(cuid())
  name         String   @unique 
  instructions String   
  flows        TemplateExecutionFlow[]
}
