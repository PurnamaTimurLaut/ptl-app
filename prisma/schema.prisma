generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String
  createdAt DateTime @default(now())
}

model Project {
  id          String       @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  budget      Float
  status      String       @default("RUNNING")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  projectCode String?      @unique
  productions Production[]
}

model Production {
  id                 String             @id @default(cuid())
  projectId          String
  menuId             String
  quantity           Int
  assignedDate       DateTime
  deadlineDate       DateTime
  status             String             @default("ASSIGNED")
  productionCode     String?            @unique
  ProductionTemplate ProductionTemplate @relation(fields: [menuId], references: [id])
  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProductionTemplate {
  id          String                  @id @default(cuid())
  name        String                  @unique
  shortCode   String?                 @unique
  Production  Production[]
  flows       TemplateExecutionFlow[]
  ingredients TemplateIngredient[]
}

model TemplateIngredient {
  id         String             @id @default(cuid())
  templateId String
  name       String
  quantity   Float
  unit       String
  template   ProductionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model TemplateExecutionFlow {
  id         String             @id @default(cuid())
  templateId String
  name       String
  recipeId   String?
  recipe     CookingRecipe?     @relation(fields: [recipeId], references: [id])
  template   ProductionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model CookingRecipe {
  id           String                  @id @default(cuid())
  name         String                  @unique
  instructions String
  flows        TemplateExecutionFlow[]
}

model InventoryItem {
  id               String               @id @default(cuid())
  itemSequenceCode Int                  @unique @default(autoincrement())
  name             String
  unit             String
  status           String               @default("ok")
  lastAudit        DateTime             @default(now())
  containers       InventoryContainer[]
  logs             InventoryLog[]
}

model InventoryContainer {
  id     String        @id @default(cuid())
  itemId String
  name   String
  type   ContainerType
  amount Float         @default(0)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model InventoryLog {
  id            String        @id @default(cuid())
  itemId        String
  uniqueCode    String        @unique
  actionType    LogActionType
  title         String
  locationInfo  String
  referenceInfo String
  createdAt     DateTime      @default(now())
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

enum ContainerType {
  ACTIVE
  RESERVE
  UNASSIGNED
}

enum LogActionType {
  STOCK_ADJUSTMENT
  MOVE_STOCK
  BUY_STOCK
  ASSIGN_STOCK
}
